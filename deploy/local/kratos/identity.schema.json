{
  "$id": "https://helixforge.local/schemas/identity.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HelixForge Identity",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "title": "E-Mail",
          "ory.sh/kratos": {
            "credentials": {
              "password": {
                "identifier": true
              }
            },
            "recovery": {
              "via": "email"
            },
            "verification": {
              "via": "email"
            }
          }
        },
        "name": {
          "type": "object",
          "properties": {
            "first": { "type": "string" },
            "last": { "type": "string" }
          }
        },
        "tenant_id": {
          "type": "string",
          "format": "uuid",
          "title": "Tenant ID",
          "description": "Helix tenant UUID (also set via metadata_public.tenant_id)"
        },
        "residency_region": {
          "type": "string",
          "enum": ["local", "eu-west", "us-east", "ap-south"],
          "title": "Data residency region"
        },
        "org_id": {
          "type": "string",
          "format": "uuid",
          "title": "Organization ID"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["read", "write", "admin", "platform", "audit_read"]
          },
          "title": "Helix roles"
        },
        "email_verified": {
          "type": "boolean",
          "title": "E-Mail verified"
        }
      },
      "required": ["email"],
      "additionalProperties": false
    }
  }
}
